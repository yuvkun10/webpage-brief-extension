{
  "manifest_version": 3,
  "name": "Webpage Brief",
  "version": "1.0.0",
  "description": "Summarize the current webpage locally with deterministic extractive logic.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Webpage Brief",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting"]
}
